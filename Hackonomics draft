        "from IPython.display import HTML, display\n",
        "\n",
        "html_code = r\"\"\"\n",
        "<!DOCTYPE html>\n",
        "<html lang=\"en\">\n",
        "<head>\n",
        "<meta charset=\"UTF-8\">\n",
        "<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n",
        "<title>MoneyMind</title>\n",
        "\n",
        "<script src=\"https://cdn.jsdelivr.net/npm/chart.js\"></script>\n",
        "\n",
        "<style>\n",
        "body {\n",
        "    background: #0a0a0f;\n",
        "    color: white;\n",
        "    font-family: Arial;\n",
        "    text-align: center;\n",
        "}\n",
        "\n",
        ".container {\n",
        "    max-width: 700px;\n",
        "    margin: auto;\n",
        "    background: #111118;\n",
        "    padding: 20px;\n",
        "    border-radius: 12px;\n",
        "}\n",
        "\n",
        "h1 {\n",
        "    color: #c8f557;\n",
        "}\n",
        "\n",
        "input {\n",
        "    width: 90%;\n",
        "    padding: 10px;\n",
        "    margin: 8px;\n",
        "    background: #18181f;\n",
        "    border: none;\n",
        "    color: white;\n",
        "}\n",
        "\n",
        "button {\n",
        "    padding: 10px 20px;\n",
        "    background: #c8f557;\n",
        "    border: none;\n",
        "    cursor: pointer;\n",
        "    font-weight: bold;\n",
        "    margin-top: 10px;\n",
        "}\n",
        "\n",
        ".result {\n",
        "    margin-top: 15px;\n",
        "    font-size: 20px;\n",
        "    color: #c8f557;\n",
        "}\n",
        "\n",
        "canvas {\n",
        "    margin-top: 20px;\n",
        "}\n",
        "</style>\n",
        "</head>\n",
        "\n",
        "<body>\n",
        "\n",
        "<div class=\"container\">\n",
        "    <h1>MoneyMind 💸</h1>\n",
        "    <p>Compound Growth Visualizer</p>\n",
        "\n",
        "    <input type=\"number\" id=\"principal\" placeholder=\"Initial Amount\">\n",
        "    <input type=\"number\" id=\"monthly\" placeholder=\"Monthly Contribution\">\n",
        "    <input type=\"number\" id=\"rate\" placeholder=\"Interest Rate (%)\">\n",
        "    <input type=\"number\" id=\"years\" placeholder=\"Years\">\n",
        "\n",
        "    <br>\n",
        "    <button onclick=\"calculate()\">Calculate</button>\n",
        "\n",
        "    <div class=\"result\" id=\"output\"></div>\n",
        "\n",
        "    <canvas id=\"chart\"></canvas>\n",
        "</div>\n",
        "\n",
        "<script>\n",
        "let chart;\n",
        "\n",
        "function calculate() {\n",
        "    let p = parseFloat(document.getElementById('principal').value) || 0;\n",
        "    let m = parseFloat(document.getElementById('monthly').value) || 0;\n",
        "    let r = (parseFloat(document.getElementById('rate').value) || 0) / 100;\n",
        "    let y = parseFloat(document.getElementById('years').value) || 0;\n",
        "\n",
        "    let months = y * 12;\n",
        "    let balance = p;\n",
        "\n",
        "    let data = [];\n",
        "    let labels = [];\n",
        "\n",
        "    for (let i = 0; i <= months; i++) {\n",
        "        balance = balance * (1 + r/12) + m;\n",
        "        data.push(balance.toFixed(2));\n",
        "        labels.push(i);\n",
        "    }\n",
        "\n",
        "    document.getElementById('output').innerText =\n",
        "        \"Final Amount: ₹\" + balance.toFixed(2);\n",
        "\n",
        "    if (chart) {\n",
        "        chart.destroy();\n",
        "    }\n",
        "\n",
        "    const ctx = document.getElementById('chart').getContext('2d');\n",
        "\n",
        "    chart = new Chart(ctx, {\n",
        "        type: 'line',\n",
        "        data: {\n",
        "            labels: labels,\n",
        "            datasets: [{\n",
        "                label: 'Growth',\n",
        "                data: data,\n",
        "                borderColor: '#c8f557',\n",
        "                fill: false\n",
        "            }]\n",
        "        }\n",
        "    });\n",
        "}\n",
        "</script>\n",
        "\n",
        "</body>\n",
        "</html>\n",
        "\"\"\"\n",
        "\n",
        "display(HTML(html_code))"
