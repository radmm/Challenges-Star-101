        "  margin-top: 15px;\n",
        "  font-size: 18px;\n",
        "  color: var(--orange);\n",
        "}\n",
        "</style>\n",
        "</head>\n",
        "\n",
        "<body>\n",
        "\n",
        "<div class=\"container\">\n",
        "\n",
        "  <h1>MoneyMind 💸</h1>\n",
        "\n",
        "  <!-- Compound Interest -->\n",
        "  <div class=\"card\">\n",
        "    <h2>Compound Calculator</h2>\n",
        "    <input id=\"p\" type=\"number\" placeholder=\"Initial Amount\">\n",
        "    <input id=\"m\" type=\"number\" placeholder=\"Monthly Contribution\">\n",
        "    <input id=\"r\" type=\"number\" placeholder=\"Interest Rate (%)\">\n",
        "    <input id=\"y\" type=\"number\" placeholder=\"Years\">\n",
        "    <button onclick=\"calcCI()\">Calculate</button>\n",
        "    <div class=\"result\" id=\"ci-result\"></div>\n",
        "    <canvas id=\"ciChart\"></canvas>\n",
        "  </div>\n",
        "\n",
        "  <!-- Inflation -->\n",
        "  <div class=\"card\">\n",
        "    <h2>Inflation Impact</h2>\n",
        "    <input id=\"inf-amt\" type=\"number\" placeholder=\"Amount Today\">\n",
        "    <input id=\"inf-rate\" type=\"number\" placeholder=\"Inflation Rate (%)\">\n",
        "    <input id=\"inf-years\" type=\"number\" placeholder=\"Years\">\n",
        "    <button onclick=\"calcInflation()\">Calculate</button>\n",
        "    <div class=\"result\" id=\"inf-result\"></div>\n",
        "  </div>\n",
        "\n",
        "</div>\n",
        "\n",
        "<script>\n",
        "let chart;\n",
        "\n",
        "// Compound Interest\n",
        "function calcCI() {\n",
        "  let p = parseFloat(document.getElementById('p').value) || 0;\n",
        "  let m = parseFloat(document.getElementById('m').value) || 0;\n",
        "  let r = (parseFloat(document.getElementById('r').value) || 0) / 100;\n",
        "  let y = parseFloat(document.getElementById('y').value) || 0;\n",
        "\n",
        "  let months = y * 12;\n",
        "  let balance = p;\n",
        "\n",
        "  let data = [];\n",
        "  let labels = [];\n",
        "\n",
        "  for (let i = 0; i <= months; i++) {\n",
        "    balance = balance * (1 + r/12) + m;\n",
        "    data.push(balance.toFixed(2));\n",
        "    labels.push(i);\n",
        "  }\n",
        "\n",
        "  document.getElementById('ci-result').innerText =\n",
        "    \"Final Amount: ₹\" + balance.toFixed(2);\n",
        "\n",
        "  if (chart) chart.destroy();\n",
        "\n",
        "  const ctx = document.getElementById('ciChart').getContext('2d');\n",
        "\n",
        "  chart = new Chart(ctx, {\n",
        "    type: 'line',\n",
        "    data: {\n",
        "      labels: labels,\n",
        "      datasets: [{\n",
        "        label: 'Growth',\n",
        "        data: data,\n",
        "        borderColor: '#c8f557',\n",
        "        fill: false\n",
        "      }]\n",
        "    }\n",
        "  });\n",
        "}\n",
        "\n",
        "// Inflation\n",
        "function calcInflation() {\n",
        "  let amt = parseFloat(document.getElementById('inf-amt').value) || 0;\n",
        "  let rate = (parseFloat(document.getElementById('inf-rate').value) || 0)/100;\n",
        "  let years = parseFloat(document.getElementById('inf-years').value) || 0;\n",
        "\n",
        "  let future = amt / Math.pow(1 + rate, years);\n",
        "\n",
        "  document.getElementById('inf-result').innerText =\n",
        "    \"Future Value (Purchasing Power): ₹\" + future.toFixed(2);\n",
        "}\n",
        "\n",
        "// Init (prevents blank UI bugs)\n",
        "window.onload = () => {\n",
        "  document.getElementById('ci-result').innerText = \"Enter values to calculate\";\n",
        "  document.getElementById('inf-result').innerText = \"Enter values to calculate\";\n",
        "};\n",
        "</script>\n",
        "\n",
        "</body>\n",
        "</html>\n",
        "\"\"\"\n",
