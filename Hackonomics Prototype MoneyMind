        "\n",
        "function drawDonut(id,a,b,c1,c2){\n",
        "  const canvas=document.getElementById(id);\n",
        "  if(!canvas)return;\n",
        "  const ctx=canvas.getContext('2d');\n",
        "  const cx=60,cy=60,r=52,inner=36;\n",
        "  ctx.clearRect(0,0,120,120);\n",
        "  const segs=[{v:a,c:c1},{v:b,c:c2}];\n",
        "  const total=a+b||1;\n",
        "  let ang=-Math.PI/2;\n",
        "  segs.forEach(s=>{\n",
        "    const sl=(s.v/total)*Math.PI*2;\n",
        "    ctx.beginPath();ctx.moveTo(cx,cy);\n",
        "    ctx.arc(cx,cy,r,ang,ang+sl);ctx.closePath();\n",
        "    ctx.fillStyle=s.c;ctx.fill();\n",
        "    ang+=sl;\n",
        "  });\n",
        "  ctx.beginPath();ctx.arc(cx,cy,inner,0,Math.PI*2);\n",
        "  ctx.fillStyle='rgba(253,248,240,0.95)';ctx.fill();\n",
        "}\n",
