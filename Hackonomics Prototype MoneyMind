        "    <div class=\"nav-pill\">Hackonomics 2026</div>\n",
        "  </nav>\n",
        "\n",
        "  <div class=\"hero\">\n",
        "    <div class=\"hero-eyebrow\">Economics and Financial Literacy</div>\n",
        "    <h1>Understand<br>money, <em>really.</em></h1>\n",
        "    <p>Six interactive tools connecting macroeconomics to your personal finances, with an AI tutor that explains the why.</p>\n",
        "    <div class=\"hero-stats\">\n",
        "      <div><div class=\"hstat-n\">6</div><div class=\"hstat-l\">Interactive Tools</div></div>\n",
        "      <div><div class=\"hstat-n\">AI</div><div class=\"hstat-l\">Q&amp;A Tutor</div></div>\n",
        "      <div><div class=\"hstat-n\">8</div><div class=\"hstat-l\">Quiz Questions</div></div>\n",
        "    </div>\n",
        "  </div>\n",
        "\n",
        "  <!-- TOOL 1: COMPOUND INTEREST -->\n",
        "\n",
        "  <div class=\"section-label\">Tool 01 - Growth Engine</div>\n",
        "  <div class=\"ci-wrap\">\n",
        "    <div class=\"ci-left\">\n",
