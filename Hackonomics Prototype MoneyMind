        "      <div class=\"tool-sub\">The math behind turning small habits into lasting wealth.</div>\n",
        "      <div class=\"big-num\" id=\"ci-final-big\"><span>$</span>0</div>\n",
        "      <div class=\"big-label\">Final Balance</div>\n",
        "      <div class=\"mini-stats\">\n",
        "        <div class=\"mini-stat\"><div class=\"mini-stat-n\" id=\"ci-mult-s\">0x</div><div class=\"mini-stat-l\">Multiplier</div></div>\n",
        "        <div class=\"mini-stat\"><div class=\"mini-stat-n\" id=\"ci-interest-s\">$0</div><div class=\"mini-stat-l\">Interest Earned</div></div>\n",
        "        <div class=\"mini-stat\"><div class=\"mini-stat-n\" id=\"ci-invested-s\">$0</div><div class=\"mini-stat-l\">You Put In</div></div>\n",
        "      </div>\n",
        "      <canvas id=\"ciCanvas\"></canvas>\n",
        "    </div>\n",
        "    <div class=\"ci-right\">\n",
        "      <div style=\"flex:1\">\n",
        "        <div class=\"slider-group\">\n",
        "          <div class=\"slider-row\"><span class=\"slider-lbl\">Initial Investment</span><span class=\"slider-val\" id=\"ci-p-v\">$1,000</span></div>\n",
        "          <input type=\"range\" id=\"ci-p\" min=\"100\" max=\"50000\" step=\"100\" value=\"1000\" oninput=\"updateCI()\">\n",
        "        </div>\n",
        "        <div class=\"slider-group\">\n",
        "          <div class=\"slider-row\"><span class=\"slider-lbl\">Monthly Contribution</span><span class=\"slider-val\" id=\"ci-m-v\">$200/mo</span></div>\n",
        "          <input type=\"range\" id=\"ci-m\" min=\"0\" max=\"2000\" step=\"25\" value=\"200\" oninput=\"updateCI()\">\n",
        "        </div>\n",
        "        <div class=\"slider-group\">\n",
        "          <div class=\"slider-row\"><span class=\"slider-lbl\">Annual Return Rate</span><span class=\"slider-val\" id=\"ci-r-v\">10%</span></div>\n",
