              "</div>\n",
              "\n",
              "<script>\n",
              "const fmt = n => {\n",
              "  if(Math.abs(n)>=1e6) return '$'+(n/1e6).toFixed(2)+'M';\n",
              "  if(Math.abs(n)>=1e3) return '$'+(n/1e3).toFixed(1)+'K';\n",
              "  return '$'+Math.round(n).toLocaleString();\n",
              "};\n",
              "const fmtFull = n => '$'+Math.round(n).toLocaleString();\n",
              "\n",
              "function updateCI() {\n",
              "  const p=+document.getElementById('ci-p').value;\n",
              "  const m=+document.getElementById('ci-m').value;\n",
              "  const r=+document.getElementById('ci-r').value/100;\n",
              "  const y=+document.getElementById('ci-y').value;\n",
              "  document.getElementById('ci-p-v').textContent=fmt(p);\n",
              "  document.getElementById('ci-m-v').textContent=fmt(m)+'/mo';\n",
              "  document.getElementById('ci-r-v').textContent=(r*100).toFixed(1)+'%';\n",
              "  document.getElementById('ci-y-v').textContent=y+' yrs';\n",
              "  document.getElementById('ci-rule-rate').textContent=(r*100).toFixed(1)+'%';\n",
              "  document.getElementById('ci-rule-yrs').textContent=(72/(r*100)).toFixed(1)+' years';\n",
              "  const mr=r/12,months=y*12;\n",
              "  let bal=p,inv=p;\n",
              "  const labels=['Now'],balData=[p],invData=[p];\n",
              "  for(let mo=1;mo<=months;mo++){\n",
              "    bal=bal*(1+mr)+m; inv+=m;\n",
              "    if(mo%12===0){labels.push('Yr'+(mo/12));balData.push(bal);invData.push(inv);}\n",
              "  }\n",
              "  const interest=bal-inv,mult=bal/inv;\n",
              "  document.getElementById('ci-final-big').innerHTML='<span>$</span>'+fmt(bal).slice(1);\n",
              "  document.getElementById('ci-mult-s').textContent=mult.toFixed(1)+'x';\n",
              "  document.getElementById('ci-interest-s').textContent=fmt(interest);\n",
              "  document.getElementById('ci-invested-s').textContent=fmt(inv);\n",
              "  drawChart('ciCanvas',labels,[\n",
              "    {label:'Balance',data:balData,color:'#f0824a'},\n",
              "    {label:'Invested',data:invData,color:'#c8e6f5',fill:'rgba(200,230,245,0.3)'}\n",
              "  ]);\n",
              "}\n",
              "\n",
              "function drawChart(id,labels,datasets) {\n",
              "  const canvas=document.getElementById(id);\n",
              "  if(!canvas)return;\n",
              "  const W=canvas.offsetWidth||700,H=220;\n",
              "  canvas.width=W;canvas.height=H;\n",
              "  const ctx=canvas.getContext('2d');\n",
              "  const pad={top:16,right:16,bottom:32,left:52};\n",
              "  const cW=W-pad.left-pad.right,cH=H-pad.top-pad.bottom;\n",
              "  ctx.clearRect(0,0,W,H);\n",
              "  const maxV=Math.max(...datasets.flatMap(d=>d.data));\n",
              "  const range=maxV||1;\n",
              "  for(let i=0;i<=4;i++){\n",
              "    const y=pad.top+cH-(i/4)*cH;\n",
              "    ctx.beginPath();ctx.strokeStyle='rgba(0,0,0,0.06)';ctx.lineWidth=1;\n",
              "    ctx.moveTo(pad.left,y);ctx.lineTo(pad.left+cW,y);ctx.stroke();\n",
              "    ctx.fillStyle='#9a8f85';ctx.font='10px Epilogue';ctx.textAlign='right';\n",
              "    ctx.fillText(fmt((i/4)*maxV),pad.left-5,y+4);\n",
              "  }\n",
              "  const step=Math.max(1,Math.floor(labels.length/5));\n",
              "  ctx.fillStyle='#9a8f85';ctx.font='10px Epilogue';ctx.textAlign='center';\n",
              "  labels.forEach((l,i)=>{\n",
              "    if(i%step===0||i===labels.length-1){\n",
              "      const x=pad.left+(i/(labels.length-1))*cW;\n",
              "      ctx.fillText(l,x,H-6);\n",
              "    }\n",
              "  });\n",
              "  datasets.forEach(ds=>{\n",
              "    const pts=ds.data.map((v,i)=>({\n",
              "      x:pad.left+(i/(ds.data.length-1))*cW,\n",
              "      y:pad.top+cH-(v/range)*cH\n",
              "    }));\n",
              "    ctx.beginPath();\n",
              "    ctx.moveTo(pts[0].x,pad.top+cH);\n",
              "    pts.forEach(p=>ctx.lineTo(p.x,p.y));\n",
              "    ctx.lineTo(pts[pts.length-1].x,pad.top+cH);\n",
              "    ctx.closePath();\n",
              "    if(ds.fill){ctx.fillStyle=ds.fill;ctx.fill();}\n",
              "    else{\n",
              "      const g=ctx.createLinearGradient(0,pad.top,0,pad.top+cH);\n",
              "      g.addColorStop(0,ds.color+'44');g.addColorStop(1,ds.color+'00');\n",
              "      ctx.fillStyle=g;ctx.fill();\n",
              "    }\n",
              "    ctx.beginPath();ctx.strokeStyle=ds.color;ctx.lineWidth=2.5;ctx.lineJoin='round';\n",
              "    pts.forEach((p,i)=>i?ctx.lineTo(p.x,p.y):ctx.moveTo(p.x,p.y));\n",
              "    ctx.stroke();\n",
              "    const last=pts[pts.length-1];\n",
              "    ctx.beginPath();ctx.arc(last.x,last.y,4,0,Math.PI*2);\n",
              "    ctx.fillStyle=ds.color;ctx.fill();\n",
              "  });\n",
              "}\n",
              "\n",
              "function updateInflation(){\n",
              "  const amt=+document.getElementById('inf-amount').value||100;\n",
              "  const yrs=+document.getElementById('inf-years').value||20;\n",
              "  const calc=r=>'$'+(amt/Math.pow(1+r,yrs)).toFixed(2);\n",
              "  document.getElementById('inf-low').textContent=calc(0.02);\n",
              "  document.getElementById('inf-avg').textContent=calc(0.04);\n",
              "  document.getElementById('inf-high').textContent=calc(0.07);\n",
              "}\n",
              "\n",
              "function updateOC(){\n",
              "  const d=+document.getElementById('oc-daily').value||0;\n",
              "  const y=+document.getElementById('oc-years').value||30;\n",
              "  const monthly=d*30,r=0.10/12,months=y*12;\n",
              "  const fv=monthly*((Math.pow(1+r,months)-1)/r);\n",
              "  document.getElementById('oc-result').textContent=fmt(fv);\n",
              "}\n",
              "\n",
              "let expenses=[\n",
              "  {name:'Rent',amt:900,cat:'needs',id:1},\n",
              "  {name:'Groceries',amt:250,cat:'needs',id:2},\n",
              "  {name:'Transport',amt:120,cat:'needs',id:3},\n",
              "  {name:'Netflix',amt:18,cat:'wants',id:4},\n",
              "  {name:'Dining out',amt:150,cat:'wants',id:5},\n",
              "  {name:'Savings',amt:400,cat:'savings',id:6},\n",
              "];\n",
              "const catColors={needs:'#5b9cf6',wants:'#f0824a',savings:'#4caf50'};\n",
              "\n",
              "function addExpense(){\n",
              "  const name=document.getElementById('exp-name').value.trim()||'Expense';\n",
              "  const amt=+document.getElementById('exp-amt').value;\n",
              "  const cat=document.getElementById('exp-cat').value;\n",
              "  if(!amt||amt<=0)return;\n",
              "  expenses.push({name,amt,cat,id:Date.now()});\n",
              "  document.getElementById('exp-name').value='';\n",
              "  document.getElementById('exp-amt').value='';\n",
              "  updateBudget();\n",
              "}\n",
              "\n",
              "function removeExpense(id){\n",
              "  expenses=expenses.filter(e=>e.id!==id);\n",
              "  updateBudget();\n",
              "}\n",
              "\n",
              "function updateBudget(){\n",
              "  const income=+document.getElementById('b-income').value||0;\n",
              "  const totals={needs:0,wants:0,savings:0};\n",
              "  expenses.forEach(e=>totals[e.cat]+=e.amt);\n",
              "  const total=totals.needs+totals.wants+totals.savings;\n",
              "  const remain=income-total;\n",
              "  document.getElementById('b-remain').textContent=(remain>=0?'+':'')+fmtFull(remain);\n",
              "  document.getElementById('b-remain').style.color=remain>=0?'var(--orange)':'var(--coral)';\n",
              "  ['needs','wants','savings'].forEach(cat=>{\n",
              "    const pct=income>0?(totals[cat]/income)*100:0;\n",
              "    const targets={needs:50,wants:30,savings:20};\n",
              "    document.getElementById(cat+'-amt').textContent=fmtFull(totals[cat]);\n",
              "    document.getElementById(cat+'-pct-lbl').textContent=pct.toFixed(0)+'% of income';\n",
              "    document.getElementById(cat+'-bar').style.width=Math.min(100,pct)+'%';\n",
              "    const diff=pct-targets[cat];\n",
              "    const target=document.getElementById(cat+'-target');\n",
              "    if(cat==='savings'){\n",
              "      target.textContent=pct>=20?'On track!':((20-pct).toFixed(0)+'% below target');\n",
              "      target.style.color=pct>=20?'#4caf50':'var(--coral)';\n",
              "    } else {\n",
              "      target.textContent=pct<=targets[cat]?'On track!':(diff.toFixed(0)+'% over target');\n",
              "      target.style.color=pct<=targets[cat]?'#4caf50':'var(--coral)';\n",
              "    }\n",
              "    const list=document.getElementById(cat+'-list');\n",
              "    list.innerHTML=expenses.filter(e=>e.cat===cat).map(e=>`\n",
              "      <div class=\"exp-item\">\n",
              "        <div class=\"exp-dot\" style=\"background:${catColors[e.cat]}\"></div>\n",
              "        <span class=\"exp-name\">${e.name}</span>\n",
              "        <span class=\"exp-amt\">$${e.amt.toLocaleString()}</span>\n",
              "        <button class=\"btn btn-danger\" onclick=\"removeExpense(${e.id})\">x</button>\n",
              "      </div>`).join('');\n",
              "  });\n",
              "}\n",
              "\n",
              "function updateDebt(){\n",
              "  const bal=+document.getElementById('d-bal').value||0;\n",
              "  const apr=+document.getElementById('d-apr').value||0;\n",
              "  const pay=+document.getElementById('d-pay').value||0;\n",
              "  const extra=+document.getElementById('d-extra').value||0;\n",
              "  const mr=(apr/100)/12;\n",
              "  function sim(b,r,p){\n",
              "    let bal=b,ti=0,months=0;const timeline=[b];\n",
              "    while(bal>0&&months<600){\n",
              "      const int=bal*r;ti+=int;bal=bal+int-p;\n",
              "      if(bal<0)bal=0;months++;timeline.push(bal);\n",
              "    }\n",
              "    return{months,totalInt:ti,timeline};\n",
              "  }\n",
              "  const base=sim(bal,mr,pay);\n",
              "  const fast=sim(bal,mr,pay+extra);\n",
              "  const saved=base.totalInt-fast.totalInt;\n",
              "  function mos(m){\n",
              "    if(m>=600)return 'Min too low';\n",
              "    const y=Math.floor(m/12),mo=m%12;\n",
              "    return(y?y+'y ':'')+( mo?mo+'m':'');\n",
              "  }\n",
              "  document.getElementById('debt-compare').innerHTML=`\n",
              "    <div class=\"debt-box\">\n",
              "      <div class=\"debt-box-title\">Minimum ($${pay}/mo)</div>\n",
              "      <div class=\"debt-row\"><span>Payoff time</span><span>${mos(base.months)}</span></div>\n",
              "      <div class=\"debt-row\"><span>Total interest</span><span>${fmtFull(base.totalInt)}</span></div>\n",
              "      <div class=\"debt-row\"><span>Total paid</span><span>${fmtFull(bal+base.totalInt)}</span></div>\n",
              "    </div>\n",
              "    <div class=\"debt-box winner\">\n",
              "      <div class=\"debt-box-title\">+ Extra $${extra}/mo</div>\n",
              "      <div class=\"debt-row\"><span>Payoff time</span><span>${mos(fast.months)}</span></div>\n",
              "      <div class=\"debt-row\"><span>Total interest</span><span>${fmtFull(fast.totalInt)}</span></div>\n",
              "      <div class=\"debt-row\"><span>You save</span><span style=\"color:#4caf50;font-weight:600\">${fmtFull(saved)}</span></div>\n",
              "    </div>`;\n",
              "  const maxMo=Math.min(base.months,360);\n",
              "  const yearLabels=Array.from({length:Math.floor(maxMo/12)+1},(_,i)=>'Yr '+i);\n",
              "  const baseY=base.timeline.filter((_,i)=>i%12===0).slice(0,yearLabels.length);\n",
              "  const fastY=fast.timeline.filter((_,i)=>i%12===0).slice(0,yearLabels.length);\n",
              "  drawChart('debtCanvas',yearLabels,[\n",
              "    {label:'Minimum only',data:baseY,color:'#f06b6b'},\n",
              "    {label:'With extra',data:fastY,color:'#4caf50',fill:'rgba(76,175,80,0.12)'}\n",
              "  ]);\n",
              "}\n",
              "\n",
              "const brackets=[\n",
              "  {min:0,max:11600,rate:0.10},{min:11600,max:47150,rate:0.12},\n",
              "  {min:47150,max:100525,rate:0.22},{min:100525,max:191950,rate:0.24},\n",
              "  {min:191950,max:243725,rate:0.32},{min:243725,max:609350,rate:0.35},\n",
              "  {min:609350,max:Infinity,rate:0.37}\n",
              "];\n",
              "\n",
              "function updateTax(){\n",
              "  const income=+document.getElementById('tax-income').value||0;\n",
              "  let tax=0,marginal=0.10;\n",
              "  brackets.forEach(b=>{\n",
              "    if(income>b.min){\n",
              "      const taxable=Math.min(income,b.max)-b.min;\n",
              "      tax+=taxable*b.rate;\n",
              "      if(income>b.min)marginal=b.rate;\n",
              "    }\n",
              "  });\n",
              "  const eff=income>0?(tax/income)*100:0;\n",
              "  document.getElementById('tax-eff').textContent=eff.toFixed(1)+'%';\n",
              "  document.getElementById('tax-marginal').textContent=(marginal*100).toFixed(0)+'%';\n",
              "  document.getElementById('tax-owed').textContent=fmtFull(tax);\n",
              "  document.getElementById('tax-home').textContent=fmtFull(income-tax);\n",
              "  drawDonut('taxDonut',eff,100-eff,'#f5c842','#5b9cf6');\n",
              "}\n",
              "\n",
              "function drawDonut(id,a,b,c1,c2){\n",
              "  const canvas=document.getElementById(id);\n",
              "  if(!canvas)return;\n",
              "  const ctx=canvas.getContext('2d');\n",
              "  const cx=60,cy=60,r=52,inner=36;\n",
              "  ctx.clearRect(0,0,120,120);\n",
              "  const segs=[{v:a,c:c1},{v:b,c:c2}];\n",
              "  const total=a+b||1;\n",
              "  let ang=-Math.PI/2;\n",
              "  segs.forEach(s=>{\n",
              "    const sl=(s.v/total)*Math.PI*2;\n",
              "    ctx.beginPath();ctx.moveTo(cx,cy);\n",
              "    ctx.arc(cx,cy,r,ang,ang+sl);ctx.closePath();\n",
              "    ctx.fillStyle=s.c;ctx.fill();\n",
              "    ang+=sl;\n",
              "  });\n",
              "  ctx.beginPath();ctx.arc(cx,cy,inner,0,Math.PI*2);\n",
              "  ctx.fillStyle='rgba(253,248,240,0.95)';ctx.fill();\n",
              "}\n",
              "\n",
              "const spScenarios=[\n",
              "  {name:'2008 Crisis (-37%)',ret:-0.37,color:'var(--coral)'},\n",
              "  {name:'Avg (10%/yr over 10yr)',ret:Math.pow(1.10,10)-1,color:'var(--orange)'},\n",
              "  {name:'Bull market (20%/yr over 10yr)',ret:Math.pow(1.20,10)-1,color:'#4caf50'},\n",
              "];\n",
              "\n",
              "function updateSP(){\n",
              "  const amt=+document.getElementById('sp-amt').value||10000;\n",
              "  document.getElementById('sp-scenarios').innerHTML=spScenarios.map(s=>`\n",
              "    <div style=\"background:rgba(255,255,255,0.7);border:1px solid rgba(255,255,255,0.9);border-radius:12px;padding:12px 14px;display:flex;justify-content:space-between;align-items:center\">\n",
              "      <div style=\"font-size:0.8rem;color:var(--ink2)\">${s.name}</div>\n",
              "      <div style=\"font-family:'Fraunces',serif;font-size:1rem;font-weight:600;color:${s.color}\">${fmtFull(amt*(1+s.ret))}</div>\n",
              "    </div>`).join('');\n",
              "}\n",
              "\n",
              "const systemPrompt=`You are Finn, a friendly economics and personal finance tutor for high school and college students. Explain economics and financial literacy concepts clearly and concisely. Connect macroeconomics (inflation, interest rates, GDP, recessions) to personal finance decisions (budgeting, investing, debt, saving). Always use simple analogies, keep answers under 150 words, be encouraging, and end with 1 brief actionable tip.`;\n",
              "\n",
              "let chatHistory=[];\n",
              "\n",
              "async function sendMessage(){\n",
              "  const input=document.getElementById('chat-input');\n",
              "  const msg=input.value.trim();\n",
              "  if(!msg)return;\n",
              "  input.value='';\n",
              "  addChatMsg(msg,'user');\n",
              "  chatHistory.push({role:'user',content:msg});\n",
              "  const typingId='typing-'+Date.now();\n",
              "  const messages=document.getElementById('chat-messages');\n",
              "  messages.innerHTML+=`<div class=\"msg msg-ai\" id=\"${typingId}\"><div class=\"msg-avatar\">🧠</div><div class=\"typing-indicator\"><div class=\"typing-dot\"></div><div class=\"typing-dot\"></div><div class=\"typing-dot\"></div></div></div>`;\n",
              "  messages.scrollTop=messages.scrollHeight;\n",
              "  try{\n",
              "    const res=await fetch('https://api.anthropic.com/v1/messages',{\n",
              "      method:'POST',\n",
              "      headers:{'Content-Type':'application/json'},\n",
              "      body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,system:systemPrompt,messages:chatHistory})\n",
              "    });\n",
              "    const data=await res.json();\n",
              "    const reply=data.content?.map(b=>b.text||'').join('')||'Sorry, try again!';\n",
              "    document.getElementById(typingId)?.remove();\n",
              "    chatHistory.push({role:'assistant',content:reply});\n",
              "    addChatMsg(reply,'ai');\n",
              "  }catch(e){\n",
              "    document.getElementById(typingId)?.remove();\n",
              "    addChatMsg('Connection trouble. Please try again.','ai');\n",
              "  }\n",
              "}\n",
              "\n",
              "function addChatMsg(text,who){\n",
              "  const messages=document.getElementById('chat-messages');\n",
              "  messages.innerHTML+=`<div class=\"msg msg-${who}\">${who==='ai'?'<div class=\"msg-avatar\">🧠</div>':''}<div class=\"msg-bubble\">${text.replace(/\\n/g,'<br>')}</div></div>`;\n",
              "  messages.scrollTop=messages.scrollHeight;\n",
              "}\n",
              "\n",
              "function askQuick(q){document.getElementById('chat-input').value=q;sendMessage();}\n",
              "\n",
              "const questions=[\n",
              "  {q:\"What does compound interest mean?\",opts:[\"Interest on your deposit only\",\"Interest on principal AND accumulated interest\",\"A bank fee\",\"Interest that decreases over time\"],ans:1,explain:\"Compound interest means you earn interest on your interest. This snowball effect is why starting to invest early has a massive impact - time multiplies your returns exponentially.\"},\n",
              "  {q:\"When the Federal Reserve raises interest rates, what typically happens to mortgage payments?\",opts:[\"They decrease\",\"They stay the same\",\"They increase\",\"They are cancelled\"],ans:2,explain:\"Higher Fed rates mean banks charge more to borrow. Mortgage rates, car loans, and credit card APRs all rise. This is how the Fed cools down an overheating economy.\"},\n",
              "  {q:\"What is the 50/30/20 budgeting rule?\",opts:[\"50% savings, 30% needs, 20% wants\",\"50% needs, 30% wants, 20% savings\",\"50% investments, 30% needs, 20% fun\",\"50% wants, 30% savings, 20% needs\"],ans:1,explain:\"50% of after-tax income to needs, 30% to wants, 20% to savings and investments. A flexible framework, not a rigid rule.\"},\n",
              "  {q:\"You have $5K credit card debt at 22% APR and $5K savings at 0.5%. What should you do?\",opts:[\"Keep all savings, pay minimums\",\"Use savings to pay off debt\",\"Invest savings in crypto\",\"Open a new credit card\"],ans:1,explain:\"Paying off 22% APR debt is a guaranteed 22% return. Nothing in investing reliably beats that. Your savings at 0.5% while paying 22% interest costs you ~21.5% per year.\"},\n",
              "  {q:\"What causes inflation?\",opts:[\"Government printing too little money\",\"Too much money chasing too few goods\",\"Stock market crashes\",\"Low unemployment\"],ans:1,explain:\"Inflation happens when money supply grows faster than goods and services. Supply chain disruptions reduce goods; stimulus increases money supply. Both push prices up.\"},\n",
              "  {q:\"The Debt Avalanche strategy means:\",opts:[\"Paying smallest debt first\",\"Ignoring all debt\",\"Paying highest-interest debt first\",\"Only paying minimums\"],ans:2,explain:\"Avalanche = highest APR debt first. Mathematically optimal - minimizes total interest paid. The Snowball method (smallest balance first) is motivating but costs more interest overall.\"},\n",
              "  {q:\"What is GDP and why does it matter?\",opts:[\"Government Debt Percentage\",\"Gross Domestic Product - measures economic output; falling GDP signals recession\",\"General Data Point - tracks stock prices\",\"Growth Dividend Percentage\"],ans:1,explain:\"GDP measures total economic output. Two consecutive quarters of falling GDP equals recession. Recessions cause job losses, credit tightening, and market drops.\"},\n",
              "  {q:\"What is marginal tax rate vs effective tax rate?\",opts:[\"They are the same thing\",\"Marginal is your top bracket rate; effective is the actual % of income paid as tax\",\"Effective is always higher than marginal\",\"Marginal applies to all your income\"],ans:1,explain:\"Marginal rate = rate on your last dollar earned. Effective rate = total taxes divided by total income. Progressive taxation means lower income is taxed at lower rates.\"}\n",
              "];\n",
              "\n",
              "let qIdx=0,qScore=0,qAnswered=false;\n",
              "\n",
              "function renderQuiz(){\n",
              "  const prog=document.getElementById('quiz-prog');\n",
              "  const area=document.getElementById('quiz-area');\n",
              "  if(qIdx>=questions.length){\n",
              "    prog.innerHTML=questions.map(()=>'<div class=\"qd done\"></div>').join('');\n",
              "    const pct=Math.round((qScore/questions.length)*100);\n",
              "    area.innerHTML=`<div style=\"text-align:center;padding:24px 0\">\n",
              "      <div style=\"font-size:2rem\">${qScore>=7?'trophy':qScore>=5?'target':'books'}</div>\n",
              "      <div class=\"quiz-big\">${qScore}<span style=\"font-size:2rem;color:var(--muted)\">/${questions.length}</span></div>\n",
              "      <div style=\"margin-top:8px;color:var(--ink2);font-size:0.9rem\">${pct}% - ${qScore>=7?'Economics expert!':qScore>=5?'Solid foundation!':'Keep exploring the tools above.'}</div>\n",
              "      <button class=\"btn btn-primary\" style=\"margin-top:24px\" onclick=\"restartQuiz()\">Try Again</button>\n",
              "    </div>`;\n",
              "    return;\n",
              "  }\n",
              "  prog.innerHTML=questions.map((_,i)=>`<div class=\"qd ${i<qIdx?'done':i===qIdx?'curr':''}\"></div>`).join('');\n",
              "  const q=questions[qIdx];\n",
              "  area.innerHTML=`\n",
              "    <div style=\"font-size:0.7rem;color:var(--muted);margin-bottom:10px;text-transform:uppercase;letter-spacing:0.8px\">Question ${qIdx+1} of ${questions.length}</div>\n",
              "    <div class=\"quiz-q-text\">${q.q}</div>\n",
              "    <div class=\"quiz-opts\">${q.opts.map((o,i)=>`<button class=\"quiz-opt\" onclick=\"answerQ(${i})\">${o}</button>`).join('')}</div>`;\n",
              "}\n",
              "\n",
              "function answerQ(idx){\n",
              "  if(qAnswered)return;\n",
              "  qAnswered=true;\n",
              "  const q=questions[qIdx];\n",
              "  document.querySelectorAll('.quiz-opt').forEach((b,i)=>{\n",
              "    b.disabled=true;\n",
              "    if(i===q.ans)b.classList.add('correct');\n",
              "    else if(i===idx&&idx!==q.ans)b.classList.add('wrong');\n",
              "  });\n",
              "  if(idx===q.ans)qScore++;\n",
              "  const area=document.getElementById('quiz-area');\n",
              "  area.innerHTML+=`<div class=\"quiz-explain\">${q.explain}</div>`;\n",
              "  area.innerHTML+=`<button class=\"btn btn-primary\" style=\"margin-top:16px\" onclick=\"nextQ()\">${qIdx<questions.length-1?'Next':'See Results'}</button>`;\n",
              "}\n",
              "\n",
              "function nextQ(){qIdx++;qAnswered=false;renderQuiz();}\n",
              "function restartQuiz(){qIdx=0;qScore=0;qAnswered=false;renderQuiz();}\n",
              "\n",
              "window.addEventListener('load',()=>{\n",
              "  setTimeout(updateCI,100);\n",
              "  updateInflation();updateOC();updateBudget();\n",
              "  updateDebt();updateTax();updateSP();renderQuiz();\n",
              "});\n",
              "window.addEventListener('resize',()=>{updateCI();updateDebt();});\n",
              "<\\/script>\n",
              "</body>\n",
              "</html>"
            ]
          },
          "metadata": {}
        }
