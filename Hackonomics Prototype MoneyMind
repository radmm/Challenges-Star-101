        "          <div style=\"font-size:0.68rem;color:var(--orange);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px\">Avg (4%)</div>\n",
        "          <div style=\"font-family:'Fraunces',serif;font-size:1.3rem;font-weight:600;color:var(--orange)\" id=\"inf-avg\">$0</div>\n",
        "        </div>\n",
