        "  color: white;\n",
        "}\n",
        "\n",
        "button {\n",
        "  padding: 10px 20px;\n",
        "  background: var(--orange);\n",
        "  border: none;\n",
        "  cursor: pointer;\n",
        "  font-weight: bold;\n",
        "}\n",
        "\n",
